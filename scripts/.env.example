RADAR_URL=https://personal-radar.pages.dev
RADAR_TOKEN=your-admin-token-here

# AI backend for trend discovery. The AI is asked for trends from its own
# knowledge plus source suggestions.
#   codex (default)  - uses your logged-in Codex CLI (ChatGPT/enterprise account, no API key)
#   claude-code      - uses your logged-in Claude Code CLI (no API key)
#   chatgpt | deepseek | claude - direct APIs, need keys below
#   ollama           - local model, free
#   none             - disable AI search
AI_BACKEND=codex

# chatgpt
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# deepseek
# DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_MODEL=deepseek-chat

# claude
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ollama (local, free)
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=qwen3:0.6b
