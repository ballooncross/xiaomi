{
  "name": "personal-radar",
  "version": "0.1.32",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test": "vitest run",
    "telegram:test": "node scripts/telegram-test.mjs",
    "gcp:runner:setup": "bash scripts/setup-gcp-runner.sh",
    "db:migrate:local": "wrangler d1 migrations apply personal-radar --local",
    "db:migrate:remote": "wrangler d1 migrations apply personal-radar --remote",
    "db:seed:local": "wrangler d1 execute personal-radar --local --file ./scripts/seed.sql",
    "db:seed:remote": "wrangler d1 execute personal-radar --remote --file ./scripts/seed.sql",
    "exercises:import:garmin": "node scripts/import-garmin-exercises.mjs",
    "exercises:seed:garmin:local": "wrangler d1 execute personal-radar --local --yes --file ./scripts/seed-garmin-exercises.sql",
    "exercises:seed:garmin:remote": "wrangler d1 execute personal-radar --remote --yes --file ./scripts/seed-garmin-exercises.sql",
    "deploy": "npm version patch --no-git-tag-version && npm run build && wrangler pages deploy .svelte-kit/cloudflare --project-name personal-radar --branch main",
    "deploy:cron": "wrangler deploy --config wrangler.cron.toml",
    "secrets:sync:pages": "node scripts/sync-secrets.mjs pages",
    "secrets:sync:cron": "node scripts/sync-secrets.mjs cron",
    "agent": "npx tsx scripts/agent.ts",
    "agent:dry": "npx tsx scripts/agent.ts --dry-run"
  },
  "devDependencies": {
    "@cloudflare/puppeteer": "^1.1.0",
    "@cloudflare/workers-types": "^4.20260606.0",
    "@sveltejs/adapter-cloudflare": "^7.2.1",
    "@sveltejs/kit": "^2.48.2",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "@types/node": "^25.9.2",
    "svelte": "^5.43.3",
    "svelte-check": "^4.3.4",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vitest": "^4.0.15",
    "wrangler": "^4.98.0"
  },
  "overrides": {
    "cookie": "^0.7.2"
  },
  "dependencies": {
    "fast-xml-parser": "^5.8.0",
    "lunar-javascript": "^1.7.7",
    "vanillajs-datepicker": "^1.3.4"
  }
}
