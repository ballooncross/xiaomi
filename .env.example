# Copy this file to .env.local for normal SvelteKit development.
# Values here are optional overrides. Empty values use src/lib/server/config.ts defaults.

ADMIN_TOKEN=
PUBLIC_APP_NAME=

# Telegram
# Use the full BotFather token, including the numeric prefix before ":".
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Concert sources
TICKETMASTER_API_KEY=
BANDSINTOWN_APP_ID=

# ICA appointment checker. Used only by the cron Worker with Browser Run.
ICA_CHECK_ENABLED=false
ICA_APPLICATION_ID=
ICA_TARGET_BEFORE=2026-07-01
# Optional local fallback for the web UI trigger. Production uses the CRON_WORKER service binding.
ICA_CHECKER_URL=

# AI is optional. Set AI_ENABLED=false to force rules-only mode.
AI_ENABLED=
AI_PROVIDER=
AI_FALLBACK_PROVIDER=
AI_MAX_ITEMS_PER_DAY=
AI_MONTHLY_BUDGET_USD=
GEMINI_API_KEY=
GEMINI_MODEL=
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=
