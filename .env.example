# Copy this file to .env for normal SvelteKit development.
# Values here are optional overrides. Empty values use src/lib/server/config.ts defaults.

ADMIN_TOKEN=
PUBLIC_APP_NAME=

# Google OAuth (required for login). Create a Web client in Google Cloud Console.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Long random string used to sign the session cookie.
SESSION_SECRET=
# Comma-separated allowlist of Google accounts that may sign in.
ALLOWED_EMAILS=

# Telegram
# Use the full BotFather token, including the numeric prefix before ":".
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Shared secret used by browser extensions/tools that call /api/extension-notify.
# This is not the Telegram bot token.
EXTENSION_NOTIFY_TOKEN=

# Concert sources
TICKETMASTER_API_KEY=
BANDSINTOWN_APP_ID=

# ICA appointment checker. Used only by the cron Worker with Browser Run.
ICA_CHECK_ENABLED=false
ICA_APPLICATION_ID=
ICA_TARGET_BEFORE=2026-07-01
# Optional local fallback for the web UI trigger. Production uses the CRON_WORKER service binding.
ICA_CHECKER_URL=
# Optional external browser fallback. The cron Worker calls this only after Cloudflare Browser Run fails.
ICA_FALLBACK_CHECK_URL=
ICA_FALLBACK_TRIGGER_TOKEN=

# AI is optional. Set AI_ENABLED=false to force rules-only mode.
AI_ENABLED=
AI_PROVIDER=
AI_FALLBACK_PROVIDER=
AI_MAX_ITEMS_PER_DAY=
AI_MONTHLY_BUDGET_USD=
GEMINI_API_KEY=
GEMINI_MODEL=
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=
